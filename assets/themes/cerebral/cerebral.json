{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Cerebral",
  "author": "Cerebral Work Institute",
  "themes": [
    {
      "name": "Cerebral Dark",
      "appearance": "dark",
      "style": {
        "background": "#0D0C0A",
        "editor.background": "#0D0C0A",
        "editor.foreground": "#EDE9E0",
        "editor.gutter.background": "#0D0C0A",
        "editor.line_number": "#7A7770",
        "editor.active_line_number": "#FF3344",
        "text": "#EDE9E0",
        "text.muted": "#ABA8A0",
        "text.disabled": "#7A7770",
        "text.accent": "#FF3344",
        "border": "#EDE9E033",
        "border.focused": "#FF3344",
        "element.background": "#15140F",
        "element.hover": "#1B1914",
        "element.selected": "#EDE9E033",
        "status_bar.background": "#15140F",
        "title_bar.background": "#0D0C0A",
        "tab_bar.background": "#15140F",
        "tab.active_background": "#1B1914",
        "tab.inactive_background": "#15140F",
        "panel.background": "#15140F",
        "terminal.background": "#0D0C0A",
        "terminal.foreground": "#EDE9E0",
        "link_text.hover": "#FF1A30",
        "error": "#FF1A30",
        "warning": "#FF3344",
        "success": "#D6D3CC",
        "info": "#ABA8A0",
        "players": [
          {
            "cursor": "#FF3344",
            "selection": "#EDE9E033"
          }
        ],
        "syntax": {
          "comment": {
            "color": "#7A7770",
            "font_style": "italic"
          },
          "string": {
            "color": "#D6D3CC"
          },
          "keyword": {
            "color": "#FF3344"
          },
          "function": {
            "color": "#EDE9E0"
          },
          "type": {
            "color": "#D6D3CC"
          },
          "number": {
            "color": "#D6D3CC"
          },
          "property": {
            "color": "#ABA8A0"
          },
          "punctuation": {
            "color": "#7A7770"
          }
        }
      }
    }
  ]
}
