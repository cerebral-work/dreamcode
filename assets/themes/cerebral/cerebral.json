{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Cerebral",
  "author": "Cerebral Work Institute",
  "themes": [
    {
      "name": "Cerebral Living Terminal",
      "appearance": "dark",
      "style": {
        "background": "#11111b",
        "editor.background": "#1e1e2e",
        "editor.foreground": "#cdd6f4",
        "editor.gutter.background": "#1e1e2e",
        "editor.line_number": "#7f849c",
        "editor.active_line_number": "#cba6f7",
        "text": "#cdd6f4",
        "text.muted": "#a6adc8",
        "text.disabled": "#7f849c",
        "text.accent": "#cba6f7",
        "border": "#313244",
        "border.focused": "#cba6f7",
        "element.background": "#181825",
        "element.hover": "#313244",
        "element.selected": "#45475a",
        "status_bar.background": "#181825",
        "title_bar.background": "#11111b",
        "tab_bar.background": "#181825",
        "tab.active_background": "#1e1e2e",
        "tab.inactive_background": "#181825",
        "panel.background": "#181825",
        "terminal.background": "#11111b",
        "terminal.foreground": "#cdd6f4",
        "link_text.hover": "#b4befe",
        "error": "#f38ba8",
        "warning": "#f9e2af",
        "success": "#a6e3a1",
        "info": "#89b4fa",
        "players": [
          {
            "cursor": "#cba6f7",
            "selection": "#45475a"
          }
        ],
        "syntax": {
          "comment": {
            "color": "#7f849c",
            "font_style": "italic"
          },
          "string": {
            "color": "#a6e3a1"
          },
          "keyword": {
            "color": "#cba6f7"
          },
          "function": {
            "color": "#89b4fa"
          },
          "type": {
            "color": "#f9e2af"
          },
          "number": {
            "color": "#fab387"
          },
          "property": {
            "color": "#94e2d5"
          },
          "punctuation": {
            "color": "#a6adc8"
          }
        }
      }
    }
  ]
}
